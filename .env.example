# Copy this file to .env for local development and fill in real values.
# On Render, do NOT upload a .env file - set these same keys under
# Dashboard -> your service -> Environment instead.

# --- Database ---
# Local dev default (SQLite file in the project root):
DATABASE_URL=sqlite:///./caregiver_platform.db
# On Render, point this at your Postgres instance instead, e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Sessions (required) ---
# Any long random string. Generate one locally with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=replace-with-a-long-random-string

# --- Public URL of the deployed site (used to build links in emails) ---
BASE_URL=http://localhost:8000

# --- Claude API (optional) ---
# Only needed for AI-assisted CV tailoring (cv_engine.py). Leave blank to
# run in simulation mode.
ANTHROPIC_API_KEY=

# --- Admin routes (required to use /admin/*) ---
# Any long random string. Without this set, /admin/scrape-now,
# /admin/scraper-status, /admin/purge-expired-jobs and /admin/purge-fake-jobs
# are locked out entirely. With it set, call them as e.g.
#   /admin/scrape-now?key=YOUR_ADMIN_API_KEY
# Generate one locally with:
#   python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# --- Adzuna job listings API (optional) ---
# Free at https://developer.adzuna.com/signup - without these, the
# background scraper simply skips this source (not an error).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Outbound email for account verification (optional) ---
# Without these, registration still works - the verification link is
# printed to the server logs instead of emailed.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
